    print("Agent Log Summary")
    print("=================")
    print(f"model      : {model}")
    print(f"logs found : {log_count}")
    print(f"health     : {report['health']}")
    print()
    print(report["overall_assessment"])
    if report["top_issues"]:
        print("\nTop Issues")
        print("----------")
        for item in report["top_issues"]:
            print(f"- {item['issue']}")
            print(f"  why: {item['why_it_matters']}")
            for evidence in item["evidence"]:
                print(f"  evidence: {evidence}")
            print(f"  fix: {item['recommended_fix']}")
    if report["per_log_findings"]:
        print("\nPer Log Findings")
        print("----------------")
        for item in report["per_log_findings"]:
            print(f"- {item['log_file']} [{item['status']}]")
            print(f"  summary: {item['one_line_summary']}")
            print(f"  problem: {item['main_problem']}")
            print(f"  next: {item['next_action']}")
