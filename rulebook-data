def find_orphan_logs(log_dir: Path, rows: list[dict]) -> list[Path]:
    if not log_dir.exists():
        return []
    referenced = {Path(row["agent_log_path"]).resolve() for row in rows if row.get("agent_log_path")}
    return sorted(path.resolve() for path in log_dir.glob("*.log") if path.resolve() not in referenced)


def summarize_logs_with_model(bundle_text: str, log_count: int, model: str) -> dict:
    prompt = (
        "You are reviewing logs from a rule-generation pipeline.\n"
        "Read the entire log bundle and produce a concise but specific\n"
        "assessment of what is going wrong, what is healthy, and what the\n"
        "pipeline should change.\n\n"
        f"There are {log_count} log files in the bundle.\n"
        "Do not use heuristics or guess from filenames. Base your report only on\n"
        "the attached logs. Call out repeated failures, setup problems, tool\n"
        "issues, and anything that looks like a systemic pipeline defect.\n"
        "Return valid JSON only. Use this shape:\n"
        "{\n"
        '  "overall_assessment": "string",\n'
        '  "health": "healthy|degraded|broken|inconclusive",\n'
        '  "top_issues": [{"issue":"string","why_it_matters":"string","evidence":["string"],"recommended_fix":"string"}],\n'
        '  "per_log_findings": [{"log_file":"string","status":"string","one_line_summary":"string","main_problem":"string","next_action":"string"}],\n'
        '  "pipeline_feedback": ["string"],\n'
        '  "next_steps": ["string"]\n'
        "}"
    )
    response = deepseek_client().chat.completions.create(
        model=model,
        messages=[
            {"role": "system", "content": "You are a precise software pipeline reviewer."},
            {"role": "user", "content": f"{prompt}\n\n--- LOG BUNDLE START ---\n{bundle_text}\n--- LOG BUNDLE END ---"},
        ],
        max_tokens=4096,
        reasoning_effort="high",
        extra_body={"thinking": {"type": "enabled"}},
        response_format={"type": "json_object"},
    )
    return json.loads(response.choices[0].message.content)


