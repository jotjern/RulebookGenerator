#!/usr/bin/env python3
"""Show status for generated ScenicRules rule branches and Docker workers."""

import argparse
import json
import os
import subprocess
import sys
import time
from collections import Counter
from pathlib import Path


DEFAULT_REPO = Path(
    os.environ.get("SCENIC_RULES_PATH", "/Users/jogramnaestjernshaugen/ScenicRules")
)
DEFAULT_MANIFEST = Path("generated_rule_scenarios.json")
DEFAULT_WORKSPACES = Path(".rulegen_docker_workspaces")
DEFAULT_IMAGE = "rulebook-generator-agents:latest"


def run(cmd: list[str], cwd: Path | None = None, check: bool = False) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if check and result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(f"{' '.join(cmd)} failed: {message}")
    return result


def git(repo: Path, *args: str, check: bool = False) -> subprocess.CompletedProcess:
    return run(["git", *args], cwd=repo, check=check)


def load_manifest(path: Path) -> list[dict]:
    if not path.exists():
        return []
    data = json.loads(path.read_text())
    return data.get("entries", []) if isinstance(data, dict) else []


def list_rule_branches(repo: Path, pattern: str) -> dict[str, int | None]:
    if not repo.exists():
        return {}
    result = git(repo, "branch", "--format=%(refname:short)", "--list", pattern)
    if result.returncode != 0:
        return {}
    branches = {}
    for branch in result.stdout.splitlines():
        branch = branch.strip()
        if not branch:
            continue
        count = git(repo, "rev-list", "--count", f"main..{branch}")
        branches[branch] = int(count.stdout.strip()) if count.returncode == 0 else None
    return branches


def workspace_status(workspaces: Path) -> dict[str, dict]:
    statuses = {}
    if not workspaces.exists():
        return statuses
    for repo in sorted(workspaces.glob("*/repo")):
        branch = git(repo, "branch", "--show-current")
        status = git(repo, "status", "--short")
        ahead = git(repo, "rev-list", "--count", "origin/main..HEAD")
        branch_name = branch.stdout.strip() if branch.returncode == 0 else ""
        statuses[str(repo.resolve())] = {
            "path": str(repo),
            "branch": branch_name,
            "dirty": bool(status.stdout.strip()) if status.returncode == 0 else None,
            "ahead": int(ahead.stdout.strip()) if ahead.returncode == 0 else None,
        }
    return statuses


def docker_workers(image: str) -> list[dict]:
    ps = run([
        "docker",
        "ps",
        "--filter",
        f"ancestor={image}",
        "--format",
        "{{.ID}}",
    ])
    if ps.returncode != 0:
        return []

    workers = []
    for cid in [line.strip() for line in ps.stdout.splitlines() if line.strip()]:
        inspect = run(["docker", "inspect", cid])
        if inspect.returncode != 0:
            continue
        data = json.loads(inspect.stdout)[0]
        args = data.get("Args", [])
        mounts = data.get("Mounts", [])
        workspace = ""
        for mount in mounts:
            if mount.get("Destination") == "/workspace":
                workspace = mount.get("Source", "")
                break
        workers.append({
            "id": cid[:12],
            "status": data.get("State", {}).get("Status", ""),
            "started_at": data.get("State", {}).get("StartedAt", ""),
            "workspace": workspace,
            "command": " ".join(args[:8]),
        })
    return workers


def shorten(text: str, width: int) -> str:
    text = " ".join(str(text).split())
    return text if len(text) <= width else text[: max(0, width - 1)] + "…"


def build_rows(
    manifest_entries: list[dict],
    branches: dict[str, int | None],
    workspaces: dict[str, dict],
    workers: list[dict],
) -> list[dict]:
    by_branch = {entry.get("branch", ""): entry for entry in manifest_entries}
    workspace_by_branch = {
        info.get("branch", ""): info
        for info in workspaces.values()
        if info.get("branch")
    }
    worker_by_workspace = {
        str(Path(worker["workspace"]).resolve()): worker
        for worker in workers
        if worker.get("workspace")
    }
    all_branches = sorted(set(by_branch) | set(branches) | set(workspace_by_branch))
    rows = []
    for branch in all_branches:
        entry = by_branch.get(branch, {})
        workspace = workspace_by_branch.get(branch)
        worker = None
        if workspace:
            worker = worker_by_workspace.get(str(Path(workspace["path"]).resolve()))
        ahead = branches.get(branch)
        rows.append({
            "idx": branch.split("/", 1)[1].split("-", 1)[0] if "/" in branch else "",
            "branch": branch,
            "manifest": entry.get("status", "-"),
            "repo_ahead": ahead,
            "workspace_ahead": workspace.get("ahead") if workspace else None,
            "dirty": workspace.get("dirty") if workspace else None,
            "running": bool(worker),
            "container": worker.get("id") if worker else "",
            "scenario": entry.get("scenario_name", ""),
            "rule": entry.get("rule", ""),
        })
    return rows


def print_status(rows: list[dict], workers: list[dict], branches: dict[str, int | None]) -> None:
    manifest_counts = Counter(row["manifest"] for row in rows)
    running = sum(1 for row in rows if row["running"])
    committed = sum(1 for row in rows if row["repo_ahead"] and row["repo_ahead"] > 0)
    empty = sum(1 for row in rows if row["repo_ahead"] == 0)

    print(
        f"rules={len(rows)} running={running} committed_branches={committed} "
        f"empty_branches={empty} containers={len(workers)}"
    )
    if manifest_counts:
        print("manifest:", ", ".join(f"{k}={v}" for k, v in sorted(manifest_counts.items())))
    print()
    print(
        f"{'#':>3} {'state':<10} {'repo':>4} {'ws':>3} {'dirty':>5} "
        f"{'run':>3} {'container':<12} {'branch':<62} scenario"
    )
    print("-" * 132)
    for row in rows:
        repo_ahead = "-" if row["repo_ahead"] is None else str(row["repo_ahead"])
        ws_ahead = "-" if row["workspace_ahead"] is None else str(row["workspace_ahead"])
        dirty = "-" if row["dirty"] is None else ("yes" if row["dirty"] else "no")
        running = "yes" if row["running"] else "no"
        print(
            f"{row['idx']:>3} {row['manifest']:<10} {repo_ahead:>4} {ws_ahead:>3} "
            f"{dirty:>5} {running:>3} {row['container']:<12} "
            f"{shorten(row['branch'], 62):<62} {row['scenario']}"
        )

    extra_workers = [
        worker for worker in workers
        if not any(row["container"] == worker["id"] for row in rows)
    ]
    if extra_workers:
        print("\nUnmatched running containers:")
        for worker in extra_workers:
            print(f"  {worker['id']} {worker['status']} {worker['workspace']}")


def snapshot(args: argparse.Namespace) -> dict:
    manifest_entries = load_manifest(args.manifest)
    branches = list_rule_branches(args.repo, args.pattern)
    workspaces = workspace_status(args.workspaces)
    workers = docker_workers(args.image) if not args.no_docker else []
    rows = build_rows(manifest_entries, branches, workspaces, workers)
    return {
        "rows": rows,
        "workers": workers,
        "branches": branches,
        "manifest_path": str(args.manifest),
        "repo": str(args.repo),
        "workspaces": str(args.workspaces),
    }


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Show status for generated rule branches, workspaces, and Docker workers."
    )
    parser.add_argument("--repo", type=Path, default=DEFAULT_REPO)
    parser.add_argument("--manifest", type=Path, default=DEFAULT_MANIFEST)
    parser.add_argument("--workspaces", type=Path, default=DEFAULT_WORKSPACES)
    parser.add_argument("--image", default=DEFAULT_IMAGE)
    parser.add_argument("--pattern", default="rule/*")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    parser.add_argument("--no-docker", action="store_true", help="Skip Docker inspection.")
    parser.add_argument("--watch", type=float, default=0, help="Refresh every N seconds.")
    args = parser.parse_args()

    args.repo = args.repo.expanduser().resolve()
    args.manifest = args.manifest.expanduser().resolve()
    args.workspaces = args.workspaces.expanduser().resolve()

    while True:
        data = snapshot(args)
        if args.json:
            print(json.dumps(data, indent=2))
        else:
            print_status(data["rows"], data["workers"], data["branches"])
        if args.watch <= 0:
            return 0
        time.sleep(args.watch)
        print("\033[2J\033[H", end="")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        print(str(exc), file=sys.stderr)
        raise SystemExit(1)
