        print("\nPipeline Feedback")
        print("-----------------")
        for item in report["pipeline_feedback"]:
            print(f"- {item}")
    if report["next_steps"]:
        print("\nNext Steps")
        print("----------")
        for item in report["next_steps"]:
            print(f"- {item}")


def db_rows_from_legacy_manifest(manifest_path: Path, log_dir: Path) -> list[dict]:
    entries = load_legacy_manifest(manifest_path)
    rows: list[dict] = []
    for idx, entry in enumerate(entries):
        branch = entry.get("branch", f"entry_{idx}")
        status = entry.get("status", "unknown")
        scenario_name = entry.get("scenario_name", "")
        scenario_path = entry.get("scenario_path", "")
        log_path = Path(entry.get("agent_log_path") or (log_dir / f"{idx:03d}-{branch.split('-', 2)[-1]}.log"))
        log_exists, log_exit_code, log_status, log_error = read_log_summary(log_path)
        rows.append(
            {
                "idx": idx,
                "branch": branch,
                "category": entry.get("category", ""),
                "rule": entry.get("rule", ""),
                "status": status,
                "generated_at": entry.get("generated_at", ""),
                "updated_at": entry.get("generated_at", ""),
                "implementation_harness": entry.get("implementation_harness", ""),
                "implementation_provider": entry.get("implementation_provider", ""),
                "implementation_model": entry.get("implementation_model", ""),
                "implementation_reasoning": entry.get("implementation_reasoning", ""),
                "agent_log_path": str(log_path),
                "log_exists": log_exists,
                "log_exit_code": log_exit_code,
                "log_status": log_status,
                "log_error": log_error,
                "branch_exists": False,
                "branch_ahead": None,
                "scenario_name": scenario_name,
                "scenario_path": scenario_path,
            }
        )
    return rows


def cmd_status(args: argparse.Namespace) -> int:
    repo = args.repo.expanduser().resolve()
    db_path = args.db.expanduser().resolve()
    log_dir = args.log_dir.expanduser().resolve()
    color = supports_color(args.no_color)
    if not db_path.exists():
        raise RuntimeError(f"Database not found: {db_path}")
    conn = connect_db(db_path)
    try:
        meta = load_manifest_meta(conn)
    finally:
        conn.close()
    rows = load_rule_rows(db_path, log_dir)
    inspect_branches(repo, rows)
    if args.json:
        print(json.dumps({"meta": meta, "rows": rows, "summary": summarize_rows(rows)}, indent=2))
    else:
        print_status_dashboard(meta, rows, repo, db_path, log_dir, color)
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    log_paths = sorted(args.log_dir.expanduser().resolve().glob("*.log")) if args.log_dir.exists() else []
    if not log_paths:
        print("No agent logs found.")
        return 0
    bundle = "\n".join(
        f"=== LOG {i}/{len(log_paths)}: {path} ===\n{path.read_text(errors='replace')}\n=== END LOG {i}/{len(log_paths)} ===\n"
        for i, path in enumerate(log_paths, start=1)
    )
    report = summarize_logs_with_model(bundle, len(log_paths), args.model)
    print_log_report(report, len(log_paths), args.model)
    return 0


def manifest_like_rows(args: argparse.Namespace) -> list[dict]:
    db_path = args.db.expanduser().resolve()
    if db_path.exists():
        return load_rule_rows(db_path, args.log_dir.expanduser().resolve())
    if args.manifest.exists():
        return db_rows_from_legacy_manifest(args.manifest.expanduser().resolve(), args.log_dir.expanduser().resolve())
    return []


def find_entry(rows: list[dict], args: argparse.Namespace) -> dict:
    matches = rows
    if args.rule_id is not None:
        matches = [
            row
            for row in matches
            if row["idx"] == args.rule_id or (row["idx"] + 100) == args.rule_id
        ]
    if args.branch:
        matches = [row for row in matches if row["branch"] == args.branch]
    if args.scenario:
        matches = [row for row in matches if row.get("scenario_name") == args.scenario or row.get("scenario_path") == args.scenario]
    if not matches:
        raise RuntimeError("No entry matched the requested selector.")
    if len(matches) > 1:
        labels = "\n".join(f"  {row['branch']} -> {row['rule'][:80]}" for row in matches[:20])
        raise RuntimeError("Selector matched multiple entries. Narrow it down:\n" + labels)
    return matches[0]


def branch_exists(repo: Path, branch: str) -> bool:
    result = subprocess.run(["git", "rev-parse", "--verify", branch], cwd=repo, capture_output=True, text=True)
    return result.returncode == 0


def git(repo: Path, *args: str, capture: bool = True, check: bool = True) -> subprocess.CompletedProcess:
    kwargs = {"cwd": repo, "text": True}
    if capture:
        kwargs["capture_output"] = True
    result = subprocess.run(["git", *args], **kwargs)
    if check and result.returncode != 0:
        msg = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(f"git {' '.join(args)} failed: {msg}")
    return result


def require_clean_worktree(repo: Path) -> None:
    status = git(repo, "status", "--porcelain").stdout.strip()
    if status:
        raise RuntimeError("ScenicRules worktree has uncommitted changes. Commit/stash them or rerun with --allow-dirty.")


def current_branch(repo: Path) -> str:
    return git(repo, "branch", "--show-current").stdout.strip()


def worktree_branch_usage(repo: Path) -> dict[str, list[Path]]:
    result = subprocess.run(
        ["git", "worktree", "list", "--porcelain"],
        cwd=repo,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "failed to list worktrees"
        raise RuntimeError(message)
    usage: dict[str, list[Path]] = {}
    current_path: Path | None = None
    current_branch: str | None = None

    def flush_current() -> None:
        nonlocal current_path, current_branch
        if current_path is not None and current_branch:
            usage.setdefault(current_branch, []).append(current_path)

    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            flush_current()
            current_path = Path(line.split(" ", 1)[1].strip())
            current_branch = None
        elif line.startswith("branch "):
            current_branch = line.split(" ", 1)[1].strip()
            if current_branch.startswith("refs/heads/"):
                current_branch = current_branch.removeprefix("refs/heads/")
    flush_current()
    return usage


def extract_violation_summary(combined_log: str) -> str:
    lines_out: list[str] = []
    markers = ("Average error value:", "Rule violation count:", "Number of unique violations:", "Unique violations:")
    for line in combined_log.splitlines():
        s = line.strip()
        if not s:
            continue
        if any(m in s for m in markers):
            lines_out.append(s)
        elif "Results for " in s and "seed:" in s:
            lines_out.append(s)
    return "\n".join(lines_out)


