FROM node:22-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        fd-find \
        findutils \
        git \
        gdal-bin \
        libffi-dev \
        libgdal-dev \
        libgeos-dev \
        libgl1 \
        libproj-dev \
        libspatialindex-dev \
        libsqlite3-dev \
        libssl-dev \
        libz-dev \
        jq \
        procps \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        ripgrep \
        tree \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd

COPY docker/rulebook-agent-entrypoint.sh /usr/local/bin/rulebook-agent-entrypoint
COPY docker/install-scenicrules-env.py /usr/local/bin/install-scenicrules-env
RUN chmod +x /usr/local/bin/rulebook-agent-entrypoint
RUN chmod +x /usr/local/bin/install-scenicrules-env

ENV SCENIC_RULES_ROOT=/workspace
ENV SCENIC_RULES_WORKSPACE=/workspace
ENV RULEBOOKGEN_ROOT=/rulebookgen
ENV VENV_DIR=/opt/scenicrules-venv
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/workspace/src:/workspace
ENV PATH="/opt/scenicrules-venv/bin:${PATH}"

COPY scenicrules/ /opt/scenicrules-src/

RUN python3 -m venv /opt/scenicrules-venv \
    && /opt/scenicrules-venv/bin/python /usr/local/bin/install-scenicrules-env /opt/scenicrules-src

RUN npm install -g @mariozechner/pi-coding-agent @anthropic-ai/claude-code

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/rulebook-agent-entrypoint"]
