    print(bold("Categories", color))
    print(dim("  " + ", ".join(f"{name}={count}" for name, count in stats["category_counts"].most_common(10)), color))

    warnings = []
    stale_errors = [row for row in rows if row["status"] == "error" and row["log_error"]]
    if stats["missing_logs"]:
        warnings.append(f"{stats['missing_logs']} rows have no agent log on disk.")
    if stats["branch_missing"]:
        warnings.append(f"{stats['branch_missing']} branches are missing from ScenicRules.")
    if stale_errors:
        warnings.append(f"{len(stale_errors)} error logs contain a concrete failure line.")

    if warnings:
        print()
        print(bold("Warnings", color))
        for warning in warnings:
            print(f"  - {warning}")
        for row in stale_errors[:5]:
            print(paint_status(f"  ! {row['branch']}", color, "error"))
