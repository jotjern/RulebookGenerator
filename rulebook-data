BRANCH_RE = re.compile(r"^rule/(?P<idx>\d{3})-(?P<category>[^-]+)-(?P<slug>.+)$")
EXIT_CODE_RE = re.compile(r"^\[exit_code\]\s+(-?\d+)\s*$", re.MULTILINE)
STATUS_RE = re.compile(r"^\[status\]\s+(.+)$", re.MULTILINE)
ERROR_RE = re.compile(
    r"error|exception|traceback|failed|fatal|permission denied|not found|"
    r"no such file|timeout|rate limit|429|docker|daemon|git",
    re.I,
)

client = None


def load_dotenv(path: Path = Path(".env")) -> None:
    if not path.exists():
        return
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip().strip('"').strip("'")
        if key:
            os.environ.setdefault(key, value)


def deepseek_client() -> OpenAI:
    global client
    if client is None:
        api_key = os.environ.get("DEEPSEEK_API_KEY")
        if not api_key:
            raise RuntimeError("DEEPSEEK_API_KEY is required for log summarization.")
        client = OpenAI(api_key=api_key, base_url="https://api.deepseek.com")
    return client


def connect_db(db_path: Path) -> sqlite3.Connection:
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    return conn


def supports_color(no_color: bool) -> bool:
    return sys.stdout.isatty() and not no_color and os.environ.get("TERM") != "dumb"


def colorize(text: str, code: str, enabled: bool) -> str:
    return f"\033[{code}m{text}\033[0m" if enabled else text


def bold(text: str, enabled: bool) -> str:
    return colorize(text, "1", enabled)


def dim(text: str, enabled: bool) -> str:
    return colorize(text, "2", enabled)


def paint_status(text: str, enabled: bool, status: str) -> str:
    colors = {
        "committed": "32",
        "cached": "36",
        "empty": "33",
        "error": "31",
        "running": "35",
        "missing": "31",
        "ok": "32",
        "stale": "33",
        "unknown": "90",
        "broken": "31",
        "healthy": "32",
        "degraded": "33",
        "inconclusive": "90",
        "failed": "31",
    }
    return colorize(text, colors.get(status, "90"), enabled)


def truncate(text: str, width: int) -> str:
    text = " ".join(str(text).split())
    return text if len(text) <= width else text[: max(0, width - 1)] + "…"


def box(title: str, subtitle: str | None, enabled: bool) -> None:
    width = max(72, get_terminal_size((120, 20)).columns)
    print()
    print(colorize("=" * width, "36", enabled))
    print(bold(f"  {title}", enabled))
    if subtitle:
        print(dim(f"  {subtitle}", enabled))
    print(colorize("=" * width, "36", enabled))


def chip(label: str, value: str, enabled: bool, status: str = "unknown") -> str:
    return paint_status(f"[{label}: {value}]", enabled, status)


def parse_branch(branch: str) -> tuple[int, str]:
    match = BRANCH_RE.match(branch or "")
    if not match:
        return 9999, "other"
    return int(match.group("idx")), match.group("category")


def read_log_summary(path: Path) -> tuple[bool, int | None, str, str]:
    if not path.exists():
        return False, None, "missing", ""
    text = path.read_text(errors="replace")
    exit_match = EXIT_CODE_RE.findall(text)
    status_match = STATUS_RE.findall(text)
    error_line = ""
    for line in reversed(text.splitlines()):
        s = line.strip()
        if not s:
            continue
        if ERROR_RE.search(s):
            error_line = s
            break
    return True, int(exit_match[-1]) if exit_match else None, (status_match[-1] if status_match else "ok"), error_line


def load_manifest_meta(conn: sqlite3.Connection) -> dict:
    row = conn.execute(
        """
        SELECT scenic_rules_repo, generated_at, implementation_harness,
               implementation_provider, implementation_model, implementation_reasoning
        FROM rule_scenario_manifest
        WHERE id = 1
        """
    ).fetchone()
    return {key: row[key] for key in row.keys()} if row else {}


def load_rule_rows(db_path: Path, log_dir: Path) -> list[dict]:
    conn = connect_db(db_path)
    try:
        rows = conn.execute(
            """
            SELECT branch, rule_text, category, status, generated_at, updated_at,
                   implementation_harness, implementation_provider,
                   implementation_model, implementation_reasoning, entry_json
            FROM generated_rule_scenarios
            """
        ).fetchall()
    finally:
        conn.close()

    parsed: list[dict] = []
    for row in rows:
        entry = {}
        if row["entry_json"]:
            try:
                entry = json.loads(row["entry_json"])
            except json.JSONDecodeError:
                entry = {}

        idx, category_from_branch = parse_branch(row["branch"])
        category = row["category"] or category_from_branch
        log_path_text = entry.get("agent_log_path") or str(log_dir / f"{idx:03d}-{row['branch'].split('-', 2)[-1]}.log")
        log_exists, log_exit_code, log_status, log_error = read_log_summary(Path(log_path_text))
        parsed.append(
            {
                "idx": idx,
                "branch": row["branch"],
                "category": category,
                "rule": row["rule_text"],
                "status": row["status"] or "unknown",
                "generated_at": row["generated_at"] or "",
                "updated_at": row["updated_at"] or "",
                "implementation_harness": row["implementation_harness"] or "",
                "implementation_provider": row["implementation_provider"] or "",
                "implementation_model": row["implementation_model"] or "",
                "implementation_reasoning": row["implementation_reasoning"] or "",
                "agent_log_path": log_path_text,
                "log_exists": log_exists,
                "log_exit_code": log_exit_code,
                "log_status": log_status,
                "log_error": log_error,
                "branch_exists": False,
                "branch_ahead": None,
            }
        )
    return sorted(parsed, key=lambda r: (r["idx"], r["branch"]))


def load_legacy_manifest(manifest_path: Path) -> list[dict]:
    if not manifest_path.exists():
        return []
    data = json.loads(manifest_path.read_text())
    if isinstance(data, dict):
        return data.get("entries", [])
    if isinstance(data, list):
        return data
    return []


def inspect_branches(repo: Path, rows: list[dict]) -> None:
    if not repo.exists():
        return
    result = subprocess.run(
        ["git", "branch", "--format=%(refname:short)", "--list", "rule/*"],
        cwd=repo,
        capture_output=True,
        text=True,
    )
    existing = {line.strip() for line in result.stdout.splitlines() if line.strip()} if result.returncode == 0 else set()
    for row in rows:
        row["branch_exists"] = row["branch"] in existing
        if row["branch_exists"]:
            ahead = subprocess.run(
                ["git", "rev-list", "--count", f"main..{row['branch']}"],
                cwd=repo,
                capture_output=True,
                text=True,
            )
            row["branch_ahead"] = int(ahead.stdout.strip()) if ahead.returncode == 0 and ahead.stdout.strip().isdigit() else None


def summarize_rows(rows: list[dict]) -> dict:
    status_counts = Counter(row["status"] for row in rows)
    category_counts = Counter(row["category"] for row in rows)
    log_counts = Counter("present" if row["log_exists"] else "missing" for row in rows)
    return {
        "status_counts": status_counts,
        "category_counts": category_counts,
        "log_counts": log_counts,
        "total": len(rows),
        "errored": sum(1 for row in rows if row["status"] == "error"),
        "missing_logs": sum(1 for row in rows if not row["log_exists"]),
        "branch_missing": sum(1 for row in rows if not row["branch_exists"]),
        "branch_empty": sum(1 for row in rows if row["branch_exists"] and row["branch_ahead"] == 0),
        "branch_active": sum(1 for row in rows if row["branch_exists"] and (row["branch_ahead"] or 0) > 0),
    }


