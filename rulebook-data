                chip("committed", str(stats["status_counts"].get("committed", 0)), color, "committed"),
                chip("cached", str(stats["status_counts"].get("cached", 0)), color, "cached"),
                chip("errors", str(stats["status_counts"].get("error", 0)), color, "error"),
                chip("logs", f"{stats['log_counts'].get('present', 0)}/{stats['total']}", color, "ok"),
                chip("active branches", str(stats["branch_active"]), color, "committed"),
                chip("missing branches", str(stats["branch_missing"]), color, "missing"),
            ]
        )
    )
    if meta:
        print(
            dim(
                "  "
                f"harness: {meta.get('implementation_harness', 'unknown')}  "
                f"last run: {meta.get('generated_at', 'unknown')}  "
                f"model: {meta.get('implementation_provider', 'unknown')}/"
                f"{meta.get('implementation_model', 'unknown')}  "
                f"reasoning: {meta.get('implementation_reasoning', 'unknown')}",
                color,
            )
        )

    latest_update = max((row["updated_at"] for row in rows if row["updated_at"]), default="")
    if latest_update:
        print(dim(f"  latest row update: {latest_update}", color))

    print()
    print(bold("Status", color))
    print(f"{'#':>3}  {'db':<10} {'git':<6} {'log':<6} {'branch':<42} {'rule':<46}")
    print("-" * 120)
    for row in rows:
        db_state = paint_status(f"{row['status']:<10}", color, row["status"])
        git_state = "missing" if not row["branch_exists"] else f"+{row['branch_ahead']}" if row["branch_ahead"] is not None else "exists"
        git_state = paint_status(
            f"{git_state:<6}",
            color,
            "committed" if row["branch_ahead"] and row["branch_ahead"] > 0 else "empty" if row["branch_exists"] else "missing",
        )
        log_state = paint_status("ok    ", color, "ok") if row["log_exists"] else paint_status("missing", color, "missing")
        print(f"{row['idx']:>3}  {db_state} {git_state} {log_state} {truncate(row['branch'], 42):<42} {truncate(row['rule'], 46):<46}")

