#!/usr/bin/env python3
"""Copy stranded rule branches from .rulegen_docker_workspaces into ScenicRules.

Use when Step 5 committed inside an isolated clone but ``git fetch`` into the
real repo failed (manifest ``sync_failed``, or legacy ``error`` with ws ahead).

Example::

    ./sync-generated-workspaces
    ./sync-generated-workspaces --update-manifest
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path


def run_git(cwd: Path, *args: str, check: bool = False) -> subprocess.CompletedProcess:
    result = subprocess.run(["git", *args], cwd=cwd, capture_output=True, text=True)
    if check and result.returncode != 0:
        msg = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(f"git {' '.join(args)} failed: {msg}")
    return result


def fetch_branch_into_repo(scenic: Path, workspace_repo: Path, branch: str) -> tuple[bool, str]:
    result = run_git(
        scenic,
        "fetch",
        "--force",
        str(workspace_repo.resolve()),
        f"{branch}:refs/heads/{branch}",
    )
    if result.returncode == 0:
        return True, ""
    err = result.stderr.strip() or result.stdout.strip()
    return False, err or "(no stderr)"


def branch_ahead_of_main(repo: Path, branch: str) -> int | None:
    result = run_git(repo, "rev-list", "--count", f"main..{branch}")
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def workspace_commits_ahead(workspace_repo: Path) -> int | None:
    result = run_git(workspace_repo, "rev-list", "--count", "origin/main..HEAD")
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def load_manifest(path: Path) -> tuple[dict, list]:
    data = json.loads(path.read_text())
    entries = data.get("entries", [])
    if not isinstance(entries, list):
        entries = []
    return data, entries


def update_manifest_entries(
    scenic: Path,
    manifest_path: Path,
    synced_branches: list[str],
) -> int:
    data, entries = load_manifest(manifest_path)
    changed = 0
    for entry in entries:
        branch = entry.get("branch", "")
        if branch not in synced_branches:
            continue
        if entry.get("status") not in ("sync_failed", "error"):
            continue
        ahead = branch_ahead_of_main(scenic, branch)
        if ahead is None or ahead <= 0:
            continue
        entry["status"] = "committed"
        changed += 1
    if changed:
        data["entries"] = entries
        data["generated_at"] = datetime.now().isoformat(timespec="seconds")
        manifest_path.write_text(json.dumps(data, indent=2))
    return changed


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Fetch rule branches from Docker workspace clones into ScenicRules."
    )
    parser.add_argument(
        "--repo",
        type=Path,
        default=Path(os.environ.get("SCENIC_RULES_PATH", "/Users/jogramnaestjernshaugen/ScenicRules")),
        help="Path to ScenicRules checkout (default: $SCENIC_RULES_PATH).",
    )
    parser.add_argument(
        "--workspaces",
        type=Path,
        default=Path(".rulegen_docker_workspaces"),
        help="Directory containing per-rule workspace folders …/<slug>/repo.",
    )
    parser.add_argument(
        "--manifest",
        type=Path,
        default=Path("generated_rule_scenarios.json"),
        help="Manifest written by main.py (for --update-manifest).",
    )
    parser.add_argument(
        "--update-manifest",
        action="store_true",
        help="Set entry status to committed when the branch now exists ahead of main.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print actions only; do not fetch or modify files.",
    )
    args = parser.parse_args()

    scenic = args.repo.expanduser().resolve()
    workspaces = args.workspaces.expanduser().resolve()
    manifest_path = args.manifest.expanduser().resolve()

    if not scenic.is_dir():
        print(f"ScenicRules repo not found: {scenic}", file=sys.stderr)
        return 1

    if not workspaces.is_dir():
        print(f"Workspaces directory not found: {workspaces}", file=sys.stderr)
        return 1

    synced: list[str] = []
    ok_count = 0
    skip_count = 0

    for workspace_repo in sorted(workspaces.glob("*/repo")):
        if not workspace_repo.is_dir():
            continue
        br = run_git(workspace_repo, "branch", "--show-current")
        if br.returncode != 0:
            print(f"[skip] no branch: {workspace_repo}")
            continue
        branch = br.stdout.strip()
        if not branch:
            continue

        ahead_ws = workspace_commits_ahead(workspace_repo)
        if ahead_ws is None:
            print(f"[skip] cannot count ahead: {workspace_repo}")
            continue
        if ahead_ws == 0:
            skip_count += 1
            continue

        scenic_ahead_before = branch_ahead_of_main(scenic, branch)
        if scenic_ahead_before is not None and scenic_ahead_before >= ahead_ws:
            print(f"[ok already] {branch} scenic main..branch={scenic_ahead_before}")
            ok_count += 1
            synced.append(branch)
            continue

        print(f"[sync] {branch}  workspace_commits_ahead={ahead_ws}  {workspace_repo}")
        if args.dry_run:
            synced.append(branch)
            ok_count += 1
            continue

        success, err = fetch_branch_into_repo(scenic, workspace_repo, branch)
        if not success:
            print(f"  FAILED: {err}", file=sys.stderr)
            continue

        scenic_ahead = branch_ahead_of_main(scenic, branch)
        if scenic_ahead is None or scenic_ahead <= 0:
            print(f"  FAILED: fetch reported ok but main..{branch}={scenic_ahead}", file=sys.stderr)
            continue

        print(f"  -> scenic main..branch={scenic_ahead}")
        ok_count += 1
        synced.append(branch)

    print()
    print(f"synced={ok_count} skipped_empty_workspace={skip_count} workspaces_root={workspaces}")

    if args.update_manifest:
        if not manifest_path.is_file():
            print(f"No manifest at {manifest_path}; skipping --update-manifest", file=sys.stderr)
        elif args.dry_run:
            print("--update-manifest ignored with --dry-run")
        else:
            n = update_manifest_entries(scenic, manifest_path, synced)
            print(f"manifest entries updated to committed: {n}  ({manifest_path})")

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        print(exc, file=sys.stderr)
        raise SystemExit(1)
