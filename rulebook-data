def load_entry_selection(args: argparse.Namespace) -> tuple[list[dict], bool]:
    rows = manifest_like_rows(args)
    if args.list:
        return rows, False
    single = args.branch is not None or args.rule_id is not None or args.scenario is not None
    if single:
        return [find_entry(rows, args)], True
    n = args.batch_first_n
    if n == 0:
        return rows, True
    return rows[:n], True


def cmd_run(args: argparse.Namespace) -> int:
    repo = args.repo.expanduser().resolve()
    if not args.allow_dirty:
        require_clean_worktree(repo)
    original_branch = current_branch(repo)
    rows = manifest_like_rows(args)
    if args.list:
        for row in rows:
            print(f"{row.get('idx', ''):03d} {row.get('status', ''):10s} {row.get('branch', '')}")
        return 0
    if args.branch or args.rule_id is not None or args.scenario:
        to_run = [find_entry(rows, args)]
    else:
        to_run = rows if args.batch_first_n == 0 else rows[: args.batch_first_n]
        if not to_run:
            print("No manifest entries to run.", file=sys.stderr)
            return 1
        print(
            f"\nBatch mode: the first {len(to_run)} row(s) in file order. "
            "Adjust count with --first N (alias --limit).\n",
            flush=True,
        )

    failed = 0
    try:
        for i, row in enumerate(to_run, start=1):
            print_rule_context(i, len(to_run), row)
            branch = row["branch"]
            scenario_name = row.get("scenario_name", "")
            scenario_path = row.get("scenario_path", "")
            if not branch_exists(repo, branch):
                print(f"ERROR: Branch does not exist in ScenicRules: {branch}", file=sys.stderr)
                failed += 1
                continue
            eval_dir = repo / "src" / "evaluation"
            scenario_abs = repo / scenario_path if scenario_path else None
            if scenario_abs and not scenario_abs.exists():
                print(f"ERROR: Scenario does not exist on branch {branch}: {scenario_path}", file=sys.stderr)
                failed += 1
                continue
            venv_python = repo / ".venv" / "bin" / "python"
            python_exe = args.python or (str(venv_python) if venv_python.exists() else "python3")
            git(repo, "checkout", branch, capture=False)
            overrides = args.overrides
            if overrides and overrides[0] == "--":
                overrides = overrides[1:]
            command = [
                python_exe,
                "run_evaluation.py",
                "--config-name=eval.yaml",
                "hydra.job.chdir=False",
                "hydra.output_subdir=null",
            ]
            if scenario_abs:
                command.extend(
                    [
                        f"scenic.file_path={os.path.relpath(scenario_abs, eval_dir)}",
                        f"scenic.scenario_name={scenario_name}",
                    ]
                )
            command.extend(
                [
                    f"experiment.num_samples={args.samples}",
                    f"experiment.num_seeds={args.seeds}",
                    "falsification.sampler_type=mab",
                    "falsification.active=True",
                    *overrides,
                ]
            )
            print("Running simulation:")
            print("  " + " ".join(command))
            proc = subprocess.run(command, cwd=eval_dir, capture_output=True, text=True)
            combined = (proc.stdout or "") + (proc.stderr or "")
            print(combined, end="" if combined.endswith("\n") else "\n")
            summary = extract_violation_summary(combined)
            print_violation_footer(summary, proc.returncode)
            if proc.returncode != 0:
                failed += 1
    finally:
        if args.restore and original_branch:
            cur = current_branch(repo)
            if cur != original_branch:
                print(f"Restoring {original_branch}")
                git(repo, "checkout", original_branch, capture=False, check=False)
    if len(to_run) > 1:
        print()
        print(f"Batch finished: {len(to_run) - failed}/{len(to_run)} runs succeeded, {failed} failed.")
    return 1 if failed else 0


def branch_ahead_of_main(repo: Path, branch: str) -> int | None:
    result = git(repo, "rev-list", "--count", f"main..{branch}", capture=True, check=False)
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def workspace_commits_ahead(workspace_repo: Path) -> int | None:
    result = subprocess.run(["git", "rev-list", "--count", "origin/main..HEAD"], cwd=workspace_repo, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def fetch_branch_into_repo(scenic: Path, workspace_repo: Path, branch: str) -> tuple[bool, str]:
    result = subprocess.run(
        ["git", "fetch", "--force", str(workspace_repo.resolve()), f"{branch}:refs/heads/{branch}"],
        cwd=scenic,
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return True, ""
    err = result.stderr.strip() or result.stdout.strip()
    return False, err or "(no stderr)"


def update_manifest_entries(db_path: Path, synced_branches: list[str]) -> int:
    conn = connect_db(db_path)
    try:
        rows = conn.execute("SELECT branch, entry_json FROM generated_rule_scenarios").fetchall()
        changed = 0
        for row in rows:
            branch = row["branch"]
            if branch not in synced_branches:
                continue
            try:
                entry = json.loads(row["entry_json"])
            except json.JSONDecodeError:
                entry = {}
            if entry.get("status") not in ("sync_failed", "error", "empty"):
                continue
            entry["status"] = "committed"
            conn.execute(
                "UPDATE generated_rule_scenarios SET status = ?, entry_json = ?, updated_at = CURRENT_TIMESTAMP WHERE branch = ?",
                ("committed", json.dumps(entry, indent=2), branch),
            )
            changed += 1
        if changed:
            conn.commit()
        return changed
    finally:
        conn.close()


def delete_generated_branches(repo: Path) -> list[str]:
    result = subprocess.run(
        ["git", "branch", "--format=%(refname:short)", "--list", "rule/*"],
        cwd=repo,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or "failed to list generated branches")
    branches = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    usage = worktree_branch_usage(repo)
    removed: list[str] = []
    current = current_branch(repo)
    if current in branches:
        status = git(repo, "status", "--porcelain").stdout.strip()
        if status:
            raise RuntimeError(
                f"Cannot purge while ScenicRules worktree is dirty on {current}. "
                "Commit or stash changes first."
            )
        git(repo, "checkout", "main", capture=False)
    for branch in branches:
        holders = usage.get(branch, [])
        other_holders = [path for path in holders if path.resolve() != repo.resolve()]
        if other_holders:
            raise RuntimeError(
                f"Cannot delete branch {branch}; it is still checked out in: "
                + ", ".join(str(path) for path in other_holders)
            )
        delete = subprocess.run(
            ["git", "branch", "-D", branch],
            cwd=repo,
            capture_output=True,
            text=True,
        )
        if delete.returncode != 0:
            message = delete.stderr.strip() or delete.stdout.strip()
            raise RuntimeError(f"git branch -D {branch} failed: {message}")
        removed.append(branch)
    return removed


def cmd_purge(args: argparse.Namespace) -> int:
    if not args.yes:
        print("This will permanently delete generated rule branches in ScenicRules.")
        print("It will not touch the SQLite database, logs, workspaces, or caches.")
        print()
        if not sys.stdin.isatty():
            print("Refusing to purge without --yes in non-interactive mode.", file=sys.stderr)
            return 1
        answer = input("Type 'purge-generated' to continue: ").strip().lower()
        if answer != "purge-generated":
            print("Aborted.")
            return 1

    deleted_branches = delete_generated_branches(args.repo)

    if deleted_branches:
        print("Deleted branches:")
        for branch in deleted_branches:
            print(f"  - {branch}")
    else:
        print("Deleted branches: none")
    return 0


def cmd_sync(args: argparse.Namespace) -> int:
    scenic = args.repo.expanduser().resolve()
    workspaces = args.workspaces.expanduser().resolve()
    db_path = args.db.expanduser().resolve()
    if not scenic.is_dir():
        print(f"ScenicRules repo not found: {scenic}", file=sys.stderr)
        return 1
    if not workspaces.is_dir():
        print(f"Workspaces directory not found: {workspaces}", file=sys.stderr)
        return 1
    synced: list[str] = []
    ok_count = 0
    skip_count = 0
    for workspace_repo in sorted(workspaces.glob("*/repo")):
        if not workspace_repo.is_dir():
            continue
        br = subprocess.run(["git", "branch", "--show-current"], cwd=workspace_repo, capture_output=True, text=True)
        if br.returncode != 0:
            print(f"[skip] no branch: {workspace_repo}")
            continue
        branch = br.stdout.strip()
        if not branch:
            continue
        ahead_ws = workspace_commits_ahead(workspace_repo)
        if ahead_ws is None:
            print(f"[skip] cannot count ahead: {workspace_repo}")
            continue
        if ahead_ws == 0:
            skip_count += 1
            continue
        scenic_ahead_before = branch_ahead_of_main(scenic, branch)
        if scenic_ahead_before is not None and scenic_ahead_before >= ahead_ws:
            print(f"[ok already] {branch} scenic main..branch={scenic_ahead_before}")
            ok_count += 1
            synced.append(branch)
            continue
        print(f"[sync] {branch}  workspace_commits_ahead={ahead_ws}  {workspace_repo}")
        if args.dry_run:
            synced.append(branch)
            ok_count += 1
            continue
        success, err = fetch_branch_into_repo(scenic, workspace_repo, branch)
        if not success:
            print(f"  FAILED: {err}", file=sys.stderr)
            continue
        scenic_ahead = branch_ahead_of_main(scenic, branch)
        if scenic_ahead is None or scenic_ahead <= 0:
            print(f"  FAILED: fetch reported ok but main..{branch}={scenic_ahead}", file=sys.stderr)
            continue
        print(f"  -> scenic main..branch={scenic_ahead}")
        ok_count += 1
        synced.append(branch)
    print()
    print(f"synced={ok_count} skipped_empty_workspace={skip_count} workspaces_root={workspaces}")
    if args.update_manifest:
        n = update_manifest_entries(db_path, synced) if not args.dry_run else 0
        if args.dry_run:
            print("--update-manifest ignored with --dry-run")
        else:
            print(f"manifest rows updated to committed: {n}")
    return 0


def cmd_summary(args: argparse.Namespace) -> int:
    log_dir = args.log_dir.expanduser().resolve()
    log_paths = sorted(log_dir.glob("*.log")) if log_dir.exists() else []
    if not log_paths:
        print("No agent logs found.")
        return 0
    bundle = "\n".join(
        f"=== LOG {i}/{len(log_paths)}: {path} ===\n{path.read_text(errors='replace')}\n=== END LOG {i}/{len(log_paths)} ===\n"
        for i, path in enumerate(log_paths, start=1)
    )
    report = summarize_logs_with_model(bundle, len(log_paths), args.model)
    print_log_report(report, len(log_paths), args.model)
    return 0


def cmd_status_legacy(args: argparse.Namespace) -> int:
    # Used when a user wants the old standalone status view with a single unified tool.
    return cmd_status(args)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Unified CLI for rulebook data and artifacts.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    p = subparsers.add_parser("status", help="Show pipeline status from SQLite, git, and logs.")
    p.add_argument("--repo", type=Path, default=DEFAULT_REPO)
    p.add_argument("--db", type=Path, default=DEFAULT_DB)
    p.add_argument("--log-dir", type=Path, default=DEFAULT_LOG_DIR)
    p.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    p.add_argument("--no-color", action="store_true", help="Disable ANSI colors.")
    p.set_defaults(func=cmd_status)

    p = subparsers.add_parser("summary", help="Summarize agent logs with DeepSeek.")
    p.add_argument("--log-dir", type=Path, default=DEFAULT_LOG_DIR)
    p.add_argument("--model", default=os.environ.get("SUMMARY_MODEL", DEFAULT_MODEL))
    p.set_defaults(func=cmd_summary)

    p = subparsers.add_parser("purge", help="Delete generated branches from ScenicRules.")
    p.add_argument("--repo", type=Path, default=DEFAULT_REPO)
    p.add_argument("--yes", action="store_true", help="Actually perform the purge without prompting.")
    p.set_defaults(func=cmd_purge)

    p = subparsers.add_parser("run", help="Run generated rule entries.")
    p.add_argument("--manifest", type=Path, default=DEFAULT_LEGACY_MANIFEST, help="Legacy manifest path; DB is preferred.")
    p.add_argument("--db", type=Path, default=DEFAULT_DB)
    p.add_argument("--repo", type=Path, default=DEFAULT_REPO)
    p.add_argument("--branch", help="Generated branch to checkout.")
    p.add_argument("--scenario", help="Scenario name or repo-relative path.")
    p.add_argument("--rule-id", type=int, help="Generated rule id.")
    p.add_argument("--first", "--limit", type=int, default=DEFAULT_BATCH_LIMIT, metavar="N", dest="batch_first_n")
    p.add_argument("--list", action="store_true", help="List available entries and exit.")
    p.add_argument("--samples", type=int, default=1)
    p.add_argument("--seeds", type=int, default=1)
    p.add_argument("--python", default=None)
    p.add_argument("--allow-dirty", action="store_true")
    p.add_argument("--restore", action="store_true")
    p.add_argument("overrides", nargs=argparse.REMAINDER)
    p.set_defaults(func=cmd_run)

    p = subparsers.add_parser("sync", help="Fetch committed workspaces back into ScenicRules.")
    p.add_argument("--repo", type=Path, default=DEFAULT_REPO)
    p.add_argument("--workspaces", type=Path, default=DEFAULT_WORKSPACES)
    p.add_argument("--db", type=Path, default=DEFAULT_DB)
    p.add_argument("--update-manifest", action="store_true")
    p.add_argument("--dry-run", action="store_true")
    p.set_defaults(func=cmd_sync)

    return parser


def main(argv: list[str] | None = None) -> int:
    load_dotenv()
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.command in {"status", "summary", "run", "sync", "purge"}:
        if hasattr(args, "repo"):
            args.repo = args.repo.expanduser().resolve()
        if hasattr(args, "db"):
            args.db = args.db.expanduser().resolve()
        if hasattr(args, "log_dir"):
            args.log_dir = args.log_dir.expanduser().resolve()
        if hasattr(args, "workspaces"):
            args.workspaces = args.workspaces.expanduser().resolve()
        if hasattr(args, "manifest"):
            args.manifest = args.manifest.expanduser().resolve()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
